@model IEnumerable<Library.BLL.ModelVM.Borrow.BorrowedBookVM>

@{
    ViewData["Title"] = "My Borrowed Books";
    var records        = Model?.ToList() ?? new List<Library.BLL.ModelVM.Borrow.BorrowedBookVM>();
    var activeLoans    = records.Where(r => !r.IsReturned && !r.ReturnRequested).ToList();
    var pendingReturns = records.Where(r => !r.IsReturned &&  r.ReturnRequested).ToList();
    var returnedLoans  = records.Where(r =>  r.IsReturned).ToList();
}

<!-- ── Hero ─────────────────────────────────────────────────── -->
<div class="myborrow-hero">
    <div class="myborrow-hero-inner">
        <a asp-controller="Library" asp-action="Index" class="back-link">
            <i class="bi bi-arrow-left me-1"></i>Back to Library
        </a>
        <h1 class="myborrow-title">My Borrowed Books</h1>
        <div class="myborrow-stats">
            <div class="stat-pill stat-pill--active">
                <i class="bi bi-bookmark-fill me-1"></i>
                <strong>@activeLoans.Count</strong> active
            </div>
            @if (pendingReturns.Any())
            {
                <div class="stat-pill stat-pill--pending">
                    <i class="bi bi-hourglass-split me-1"></i>
                    <strong>@pendingReturns.Count</strong> awaiting approval
                </div>
            }
            <div class="stat-pill stat-pill--returned">
                <i class="bi bi-check2-circle me-1"></i>
                <strong>@returnedLoans.Count</strong> returned
            </div>
        </div>
    </div>
</div>

<!-- ── Content ───────────────────────────────────────────────── -->
<div class="container-fluid borrow-container">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show borrow-alert" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show borrow-alert" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!records.Any())
    {
        <div class="borrow-empty">
            <div class="borrow-empty-icon"><i class="bi bi-bookmark"></i></div>
            <h4>No borrowed books yet</h4>
            <p>Head over to the library and pick your first book!</p>
            <a asp-controller="Library" asp-action="Index" class="btn btn-browse mt-2">
                <i class="bi bi-bookshelf me-2"></i>Browse Library
            </a>
        </div>
    }
    else
    {
        <!-- ══ SECTION 1: Active Loans ══════════════════════════ -->
        @if (activeLoans.Any())
        {
            <div class="section-header">
                <div class="section-dot section-dot--active"></div>
                <h2 class="section-title">Currently Borrowed</h2>
                <span class="section-count section-count--active">@activeLoans.Count</span>
            </div>

            <div class="borrow-grid mb-5">
                @foreach (var r in activeLoans)
                {
                    <div class="borrow-card borrow-card--active">
                        <div class="borrow-cover-wrap">
                            @if (!string.IsNullOrEmpty(r.ImagePath))
                            { <img src="~/files/@r.ImagePath" alt="@r.Title" class="borrow-cover-img" /> }
                            else
                            { <div class="borrow-cover-placeholder"><i class="bi bi-book"></i></div> }
                            <span class="borrow-status-badge borrow-status-badge--active">Active</span>
                        </div>
                        <div class="borrow-card-body">
                            <h3 class="borrow-book-title" title="@r.Title">@r.Title</h3>
                            <p class="borrow-book-author">
                                <i class="bi bi-person-circle me-1 opacity-50"></i>@r.Author
                            </p>
                            <span class="borrow-category-tag">@r.Category</span>
                            <div class="borrow-dates">
                                <div class="date-item">
                                    <span class="date-label">Borrowed</span>
                                    <span class="date-value">
                                        <i class="bi bi-calendar-event me-1"></i>@r.BorrowDate.ToString("dd MMM yyyy")
                                    </span>
                                </div>
                                <div class="date-item">
                                    <span class="date-label">Duration</span>
                                    <span class="date-value">
                                        <i class="bi bi-clock-history me-1"></i>
                                        @((DateTime.Now - r.BorrowDate).Days) day@((DateTime.Now - r.BorrowDate).Days == 1 ? "" : "s")
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="borrow-card-footer">
                            <button type="button" class="btn-request-return w-100"
                                    onclick="confirmRequestReturn(@r.BorrowId, '@Html.Raw(r.Title.Replace("'","\\'"))')">
                                <i class="bi bi-send me-2"></i>Request Return
                            </button>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- ══ SECTION 2: Pending Approval ══════════════════════ -->
        @if (pendingReturns.Any())
        {
            <div class="section-header">
                <div class="section-dot section-dot--pending"></div>
                <h2 class="section-title">Awaiting Return Approval</h2>
                <span class="section-count section-count--pending">@pendingReturns.Count</span>
            </div>

            <div class="pending-info-banner mb-3">
                <i class="bi bi-info-circle-fill me-2"></i>
                Your return request has been submitted. An admin will confirm and update your record. The book stays in your account until confirmed.
            </div>

            <div class="borrow-grid mb-5">
                @foreach (var r in pendingReturns)
                {
                    <div class="borrow-card borrow-card--pending">
                        <div class="borrow-cover-wrap">
                            @if (!string.IsNullOrEmpty(r.ImagePath))
                            { <img src="~/files/@r.ImagePath" alt="@r.Title" class="borrow-cover-img cover-pending" /> }
                            else
                            { <div class="borrow-cover-placeholder cover-pending-ph"><i class="bi bi-book"></i></div> }
                            <span class="borrow-status-badge borrow-status-badge--pending">
                                <i class="bi bi-hourglass-split me-1"></i>Pending
                            </span>
                        </div>
                        <div class="borrow-card-body">
                            <h3 class="borrow-book-title" title="@r.Title">@r.Title</h3>
                            <p class="borrow-book-author">
                                <i class="bi bi-person-circle me-1 opacity-50"></i>@r.Author
                            </p>
                            <span class="borrow-category-tag">@r.Category</span>
                            <div class="borrow-dates">
                                <div class="date-item">
                                    <span class="date-label">Borrowed</span>
                                    <span class="date-value">
                                        <i class="bi bi-calendar-event me-1"></i>@r.BorrowDate.ToString("dd MMM yyyy")
                                    </span>
                                </div>
                                <div class="date-item">
                                    <span class="date-label">Duration</span>
                                    <span class="date-value">
                                        <i class="bi bi-clock-history me-1"></i>
                                        @((DateTime.Now - r.BorrowDate).Days) day@((DateTime.Now - r.BorrowDate).Days == 1 ? "" : "s")
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="borrow-card-footer">
                            <div class="pending-footer-msg">
                                <i class="bi bi-clock-history me-1"></i>
                                Waiting for admin confirmation
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- ══ SECTION 3: Return History ════════════════════════ -->
        @if (returnedLoans.Any())
        {
            <div class="section-header">
                <div class="section-dot section-dot--returned"></div>
                <h2 class="section-title">Return History</h2>
                <span class="section-count section-count--muted">@returnedLoans.Count</span>
            </div>

            <div class="history-table-wrap">
                <table class="table history-table">
                    <thead>
                        <tr>
                            <th style="width:50px"></th>
                            <th>Book</th>
                            <th>Author</th>
                            <th>Category</th>
                            <th>Borrowed</th>
                            <th>Returned</th>
                            <th class="text-center">Duration</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in returnedLoans)
                        {
                            var duration = r.ReturnDate.HasValue ? (r.ReturnDate.Value - r.BorrowDate).Days : 0;
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(r.ImagePath))
                                    { <img src="~/files/@r.ImagePath" alt="@r.Title" class="history-thumb rounded" /> }
                                    else
                                    { <div class="history-thumb-ph rounded d-flex align-items-center justify-content-center"><i class="bi bi-book text-muted"></i></div> }
                                </td>
                                <td class="fw-semibold align-middle">@r.Title</td>
                                <td class="text-muted align-middle small">@r.Author</td>
                                <td class="align-middle"><span class="cat-badge">@r.Category</span></td>
                                <td class="align-middle small text-muted">@r.BorrowDate.ToString("dd MMM yyyy")</td>
                                <td class="align-middle small text-muted">@(r.ReturnDate?.ToString("dd MMM yyyy") ?? "—")</td>
                                <td class="align-middle text-center"><span class="duration-badge">@duration d</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</div>

<!-- ── Request Return Confirmation Modal ─────────────────────── -->
<div class="modal fade" id="requestReturnModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content return-modal-content">
            <div class="modal-body text-center p-4">
                <div class="return-icon-wrap mb-3">
                    <i class="bi bi-send-fill"></i>
                </div>
                <h5 class="fw-bold mb-1">Request Return?</h5>
                <p class="text-muted small mb-0">
                    You are requesting to return<br>
                    <strong id="returnBookTitle"></strong>
                </p>
                <div class="pending-modal-note mt-2">
                    <i class="bi bi-info-circle me-1"></i>
                    The book stays in your account until an admin confirms the return.
                </div>
                <form asp-controller="Borrow" asp-action="RequestReturn" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="returnRecordId" name="BorrowId" value="" />
                    <div class="d-flex gap-2 justify-content-center mt-3">
                        <button type="button" class="btn btn-light btn-sm px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn-request-return-sm btn-sm px-4">
                            <i class="bi bi-send me-1"></i>Submit Request
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
<style>
    @@import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,500;0,600;0,700;1,500&family=DM+Sans:wght@400;500;600&display=swap');
    :root {
        --lib-cream:#faf7f2;--lib-warm:#f5efe4;--lib-border:#e8dfd0;
        --lib-ink:#1c1410;--lib-muted:#7a6e62;
        --lib-amber:#c9813a;--lib-amber-lt:#fdf0e0;
        --lib-green:#2d7a4f;--lib-green-lt:#e6f5ed;
        --lib-teal:#0e7490;--lib-teal-lt:#e0f2fe;
        --lib-pending:#b45309;--lib-pending-lt:#fef3c7;--lib-pending-border:#fde68a;
    }
    body { background:var(--lib-cream);font-family:'DM Sans',sans-serif; }

    /* Hero */
    .myborrow-hero{background:linear-gradient(135deg,#1a2e1a 0%,#2d4a2d 60%,#3d5c3d 100%);padding:3rem 0 2.5rem;}
    .myborrow-hero-inner{max-width:1000px;margin:0 auto;padding:0 2rem;}
    .back-link{font-size:.78rem;color:#a3c9a3;text-decoration:none;font-weight:600;letter-spacing:.04em;text-transform:uppercase;}
    .back-link:hover{color:#fff;}
    .myborrow-title{font-family:'Lora',serif;font-size:clamp(1.8rem,4vw,2.8rem);font-weight:700;color:#fff;margin:.75rem 0 1rem;}
    .myborrow-stats{display:flex;gap:.75rem;flex-wrap:wrap;}
    .stat-pill{font-size:.78rem;font-weight:600;padding:.3em .9em;border-radius:20px;letter-spacing:.04em;}
    .stat-pill--active {background:rgba(46,160,100,.25);color:#5de085;}
    .stat-pill--pending{background:rgba(245,158,11,.25);color:#fbbf24;}
    .stat-pill--returned{background:rgba(255,255,255,.12);color:#c8d5c8;}

    /* Layout */
    .borrow-container{max-width:1000px;margin:0 auto;padding:2rem 1.5rem 4rem;}
    .borrow-alert{border-radius:10px;border:none;}

    /* Empty */
    .borrow-empty{text-align:center;padding:5rem 1rem;color:var(--lib-muted);}
    .borrow-empty-icon{width:80px;height:80px;border-radius:50%;background:var(--lib-warm);border:2px dashed var(--lib-border);display:flex;align-items:center;justify-content:center;font-size:2rem;color:var(--lib-muted);margin:0 auto 1.5rem;}
    .borrow-empty h4{font-family:'Lora',serif;color:var(--lib-ink);}
    .btn-browse{background:var(--lib-amber);color:#fff;border:none;border-radius:8px;font-weight:600;padding:.55rem 1.5rem;transition:background .2s;text-decoration:none;display:inline-block;}
    .btn-browse:hover{background:#b56e28;color:#fff;}

    /* Section headers */
    .section-header{display:flex;align-items:center;gap:.75rem;margin-bottom:1.25rem;}
    .section-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
    .section-dot--active  {background:var(--lib-green); box-shadow:0 0 0 3px var(--lib-green-lt);}
    .section-dot--pending {background:var(--lib-pending);box-shadow:0 0 0 3px var(--lib-pending-lt);}
    .section-dot--returned{background:var(--lib-muted);  box-shadow:0 0 0 3px var(--lib-border);}
    .section-title{font-family:'Lora',serif;font-size:1.15rem;font-weight:600;color:var(--lib-ink);margin:0;}
    .section-count{font-size:.72rem;font-weight:700;padding:.15em .65em;border-radius:20px;margin-left:auto;}
    .section-count--active {background:var(--lib-green-lt); color:var(--lib-green);}
    .section-count--pending{background:var(--lib-pending-lt);color:var(--lib-pending);}
    .section-count--muted  {background:var(--lib-warm);      color:var(--lib-muted);}

    /* Pending banner */
    .pending-info-banner{background:var(--lib-pending-lt);border:1px solid var(--lib-pending-border);border-left:4px solid var(--lib-pending);border-radius:10px;padding:.75rem 1rem;font-size:.84rem;color:#92400e;line-height:1.5;}

    /* Cards grid */
    .borrow-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1.25rem;}
    .borrow-card{background:#fff;border:1px solid var(--lib-border);border-radius:14px;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 2px 10px rgba(60,40,10,.08);transition:transform .2s,box-shadow .2s;animation:cardReveal .35s ease both;}
    @@keyframes cardReveal{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
    .borrow-card:hover{transform:translateY(-3px);box-shadow:0 8px 28px rgba(60,40,10,.13);}
    .borrow-card--active {border-top:3px solid var(--lib-green);}
    .borrow-card--pending{border-top:3px solid var(--lib-pending);opacity:.93;}

    /* Cover */
    .borrow-cover-wrap{position:relative;height:180px;overflow:hidden;background:#ede8e0;}
    .borrow-cover-img{width:100%;height:100%;object-fit:cover;transition:transform .4s;}
    .borrow-card:hover .borrow-cover-img{transform:scale(1.04);}
    .borrow-cover-placeholder{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:2.5rem;color:#a89880;}
    .cover-pending{filter:brightness(.88) sepia(.12);}
    .cover-pending-ph{background:#ede0c8;}

    /* Badges */
    .borrow-status-badge{position:absolute;top:8px;left:8px;font-size:.65rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:.22em .7em;border-radius:20px;}
    .borrow-status-badge--active {background:var(--lib-green-lt); color:var(--lib-green);}
    .borrow-status-badge--pending{background:var(--lib-pending-lt);color:var(--lib-pending);}

    /* Card body */
    .borrow-card-body{padding:.9rem 1rem .5rem;flex:1;}
    .borrow-book-title{font-family:'Lora',serif;font-size:.92rem;font-weight:600;color:var(--lib-ink);margin-bottom:.25rem;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;}
    .borrow-book-author{font-size:.78rem;color:var(--lib-muted);margin-bottom:.5rem;}
    .borrow-category-tag{display:inline-block;background:var(--lib-amber-lt);color:var(--lib-amber);font-size:.68rem;font-weight:700;padding:.18em .65em;border-radius:20px;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.75rem;}
    .borrow-dates{display:flex;flex-direction:column;gap:.3rem;}
    .date-item{display:flex;justify-content:space-between;align-items:center;}
    .date-label{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--lib-muted);}
    .date-value{font-size:.75rem;color:var(--lib-ink);font-weight:500;}

    /* Card footer */
    .borrow-card-footer{padding:.75rem 1rem 1rem;border-top:1px solid #f3ede4;}
    .btn-request-return{display:block;width:100%;text-align:center;background:var(--lib-amber);color:#fff;border:none;border-radius:8px;font-size:.82rem;font-weight:600;padding:.5rem .75rem;cursor:pointer;transition:background .2s,transform .1s;}
    .btn-request-return:hover{background:#b56e28;color:#fff;transform:translateY(-1px);}
    .pending-footer-msg{text-align:center;font-size:.76rem;font-weight:600;color:var(--lib-pending);background:var(--lib-pending-lt);border-radius:6px;padding:.45rem .5rem;}

    /* History table */
    .history-table-wrap{background:#fff;border:1px solid var(--lib-border);border-radius:14px;overflow:hidden;box-shadow:0 2px 10px rgba(60,40,10,.07);}
    .history-table thead tr{background:var(--lib-warm);}
    .history-table thead th{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--lib-muted);border-bottom:1px solid var(--lib-border);padding:.8rem 1rem;}
    .history-table tbody td{padding:.7rem 1rem;border-bottom:1px solid #f5f0e8;}
    .history-table tbody tr:last-child td{border-bottom:none;}
    .history-table tbody tr:hover{background:var(--lib-cream);}
    .history-thumb{width:36px;height:48px;object-fit:cover;border:1px solid var(--lib-border);}
    .history-thumb-ph{width:36px;height:48px;background:var(--lib-warm);border:1px solid var(--lib-border);}
    .cat-badge{background:var(--lib-amber-lt);color:var(--lib-amber);font-size:.68rem;font-weight:700;padding:.18em .6em;border-radius:20px;text-transform:uppercase;letter-spacing:.04em;}
    .duration-badge{background:var(--lib-teal-lt);color:var(--lib-teal);font-size:.72rem;font-weight:700;padding:.18em .65em;border-radius:20px;}

    /* Modal */
    .return-modal-content{border:none;border-radius:16px;box-shadow:0 20px 60px rgba(0,0,0,.15);}
    .return-icon-wrap{width:64px;height:64px;border-radius:50%;background:var(--lib-amber-lt);color:var(--lib-amber);font-size:1.75rem;display:flex;align-items:center;justify-content:center;margin:0 auto;}
    .pending-modal-note{font-size:.76rem;color:#92400e;background:var(--lib-pending-lt);border:1px solid var(--lib-pending-border);border-radius:8px;padding:.5rem .75rem;line-height:1.5;}
    .btn-request-return-sm{background:var(--lib-amber);color:#fff;border:none;border-radius:8px;font-weight:600;padding:.4rem 1rem;cursor:pointer;transition:background .2s;}
    .btn-request-return-sm:hover{background:#b56e28;color:#fff;}

    @@media(max-width:640px){
        .borrow-grid{grid-template-columns:repeat(auto-fill,minmax(160px,1fr));}
        .borrow-cover-wrap{height:150px;}
    }
</style>
}

@section Scripts {
<script>
    function confirmRequestReturn(BorrowId, title) {
        document.getElementById('returnBookTitle').textContent = title;
        document.getElementById('returnRecordId').value        = BorrowId;
        new bootstrap.Modal(document.getElementById('requestReturnModal')).show();
    }
</script>
}
