@model LibraryBooksVM
@using Library.BLL.ModelVM.Library
@using Library.DAL.Enums

@{
    ViewData["Title"] = "Browse Library";
    var categories = Enum.GetValues<Category>();
    var bookList = Model.Books?.ToList() ?? new List<Library.BLL.ModelVM.Book.BookVM>();
}

<!-- ── Hero Banner ──────────────────────────────────────── -->
<div class="lib-hero">
    <div class="lib-hero-inner">
        <div class="hero-label">Your Public Library</div>
        <h1 class="hero-title">Discover Your Next<br><em>Great Read</em></h1>
        <p class="hero-sub">
            Browse @bookList.Count book@(bookList.Count == 1 ? "" : "s") in our collection.
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Library" asp-action="MyBorrowedBooks" class="hero-link">
                    View my borrowed books <i class="bi bi-arrow-right ms-1"></i>
                </a>
            }
        </p>
    </div>
</div>

<!-- ── Alerts ───────────────────────────────────────────── -->
<div class="container-fluid lib-container">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show alert-lib" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show alert-lib" role="alert">
            <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (ViewBag.Error != null)
    {
        <div class="alert alert-warning alert-dismissible fade show alert-lib" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewBag.Error
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- ── Search & Filter Bar ──────────────────────────── -->
    <form method="get" asp-action="Index" asp-controller="Library" class="filter-bar">
        <div class="filter-bar-inner">
            <!-- Title search -->
            <div class="filter-field">
                <label class="filter-label">
                    <i class="bi bi-search me-1"></i>Title
                </label>
                <input type="text" name="searchTitle" value="@Model.SearchTitle"
                       class="form-control filter-input" placeholder="Search by title…" />
            </div>

            <!-- Author search -->
            <div class="filter-field">
                <label class="filter-label">
                    <i class="bi bi-person me-1"></i>Author
                </label>
                <input type="text" name="searchAuthor" value="@Model.SearchAuthor"
                       class="form-control filter-input" placeholder="Search by author…" />
            </div>

            <!-- Category filter -->
            <div class="filter-field filter-field--sm">
                <label class="filter-label">
                    <i class="bi bi-tag me-1"></i>Category
                </label>
                <select name="selectedCategory" class="form-select filter-input">
                    <option value="">All Categories</option>
                    @foreach (var cat in categories)
{
                    <option value="@((int)cat)" selected="@(Model.SelectedCategory == cat ? "selected" : null)">
                    @cat
                    </option>
}
                </select>
            </div>

            <!-- Buttons -->
            <div class="filter-actions">
                <button type="submit" class="btn btn-filter-search">
                    <i class="bi bi-funnel-fill me-1"></i>Filter
                </button>
                @if (!string.IsNullOrEmpty(Model.SearchTitle) || !string.IsNullOrEmpty(Model.SearchAuthor) || Model.SelectedCategory.HasValue)
                {
                    <a asp-action="Index" asp-controller="Library" class="btn btn-filter-clear">
                        <i class="bi bi-x-lg me-1"></i>Clear
                    </a>
                }
            </div>
        </div>
    </form>

    <!-- ── Results Summary ──────────────────────────────── -->
    <div class="results-row">
        <span class="results-count">
            <strong>@bookList.Count</strong> book@(bookList.Count == 1 ? "" : "s") found
            @if (Model.SelectedCategory.HasValue)
            {
                <span class="filter-tag">@Model.SelectedCategory</span>
            }
        </span>
    </div>

    <!-- ── Book Cards Grid ──────────────────────────────── -->
    @if (!bookList.Any())
    {
        <div class="empty-catalog">
            <div class="empty-catalog-icon">
                <i class="bi bi-bookshelf"></i>
            </div>
            <h4>No books found</h4>
            <p class="text-muted">Try adjusting your search or clearing the filters.</p>
            <a asp-action="Index" asp-controller="Library" class="btn btn-outline-secondary btn-sm mt-1">
                Clear filters
            </a>
        </div>
    }
    else
    {
        <div class="books-grid">
            @{ int cardIdx = 0; }
            @foreach (var book in bookList)
            {
                var available = book.Quantity > 0;
                <div class="book-card @(!available ? "book-card--unavailable" : "")"
                     style="animation-delay: @(cardIdx * 50)ms">
                    <!-- Cover -->
                    <div class="book-cover-wrap">
                        @if (!string.IsNullOrEmpty(book.ImagePath))
                        {
                            <img src="~/files/@book.ImagePath" alt="@book.Title" class="book-cover-img" />
                        }
                        else
                        {
                            <div class="book-cover-placeholder">
                                <i class="bi bi-book"></i>
                            </div>
                        }
                        <!-- Availability ribbon -->
                        @if (!available)
                        {
                            <div class="cover-ribbon">Unavailable</div>
                        }
                        else if (book.Quantity <= 2)
                        {
                            <div class="cover-ribbon cover-ribbon--low">Last @book.Quantity</div>
                        }

                        <!-- Category pill on hover -->
                        <span class="cover-category">@book.Category</span>
                    </div>

                    <!-- Body -->
                    <div class="book-card-body">
                        <h3 class="book-card-title" title="@book.Title">@book.Title</h3>
                        <p class="book-card-author">
                            <i class="bi bi-person-circle me-1 opacity-50"></i>@book.Author
                        </p>
                        @if (!string.IsNullOrEmpty(book.Description))
                           {
                        <p class="feat-desc">
                        @book.Description
                        </p>
                            }
                        <div class="book-card-meta">
                            <span class="meta-qty @(available ? "qty-ok" : "qty-zero")">
                                <i class="bi bi-layers me-1"></i>
                                @(available ? $"{book.Quantity} available" : "Out of stock")
                            </span>
                        </div>
                    </div>

                    <!-- Footer / Action -->
                    <div class="book-card-footer">
                        @if (!User.Identity?.IsAuthenticated ?? true)
                        {
                            <a asp-controller="Auth" asp-action="Login"
                               class="btn btn-borrow btn-borrow--ghost w-100">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Login to Borrow
                            </a>
                        }
                        else if (!available)
                        {
                            <button class="btn btn-borrow btn-borrow--disabled w-100" disabled>
                                <i class="bi bi-hourglass me-2"></i>Unavailable
                            </button>
                        }
                        else
                        {
                            <form asp-controller="Borrow" asp-action="Borrow" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="bookId" value="@book.Id" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                <button type="submit" class="btn btn-borrow w-100">
                                    <i class="bi bi-bookmark-plus me-2"></i>Borrow
                                </button>
                            </form>
                        }
                    </div>
                </div>
                cardIdx++;
            }
        </div>
    }
</div>

@section Styles {
<style>
    /* ── Fonts ── */
    @@import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,500;0,600;0,700;1,500&family=DM+Sans:wght@400;500;600&display=swap');

    :root {
        --lib-cream:    #faf7f2;
        --lib-warm:     #f5efe4;
        --lib-border:   #e8dfd0;
        --lib-ink:      #1c1410;
        --lib-muted:    #7a6e62;
        --lib-amber:    #c9813a;
        --lib-amber-lt: #fdf0e0;
        --lib-green:    #2d7a4f;
        --lib-green-lt: #e6f5ed;
        --lib-red:      #c0392b;
        --lib-red-lt:   #fdecea;
        --lib-shadow:   0 2px 12px rgba(60,40,10,.1);
        --lib-shadow-lg:0 8px 32px rgba(60,40,10,.14);
        --card-radius:  14px;
    }

    body { background: var(--lib-cream); font-family: 'DM Sans', sans-serif; }

    /* ── Hero ── */
    .lib-hero {
        background: linear-gradient(135deg, #2c1a0e 0%, #4a2c12 60%, #6b3f1a 100%);
        padding: 3.5rem 0 3rem;
        position: relative;
        overflow: hidden;
    }
    .lib-hero::before {
        content: '';
        position: absolute; inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }
    .lib-hero-inner {
        max-width: 860px;
        margin: 0 auto;
        padding: 0 2rem;
        position: relative;
        z-index: 1;
    }
    .hero-label {
        font-size: .7rem; font-weight: 600; letter-spacing: .14em;
        text-transform: uppercase; color: #d4a766; margin-bottom: .75rem;
    }
    .hero-title {
        font-family: 'Lora', serif;
        font-size: clamp(2rem, 5vw, 3.2rem);
        font-weight: 700; color: #fff; line-height: 1.2;
        margin-bottom: 1rem;
    }
    .hero-title em { color: #e8a84a; font-style: italic; }
    .hero-sub { color: #c8b89a; font-size: .95rem; }
    .hero-link { color: #e8a84a; text-decoration: none; font-weight: 600; }
    .hero-link:hover { color: #fff; }

    /* ── Container ── */
    .lib-container { max-width: 1280px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }

    /* ── Alerts ── */
    .alert-lib { border-radius: 10px; border: none; font-size: .9rem; margin-bottom: 1.25rem; }

    /* ── Filter Bar ── */
    .filter-bar {
        background: #fff;
        border: 1px solid var(--lib-border);
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.5rem;
        box-shadow: var(--lib-shadow);
    }
    .filter-bar-inner {
        display: flex; gap: 1rem; align-items: flex-end; flex-wrap: wrap;
    }
    .filter-field { flex: 1 1 180px; min-width: 160px; }
    .filter-field--sm { flex: 0 1 180px; }
    .filter-label {
        display: block; font-size: .7rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: .08em;
        color: var(--lib-muted); margin-bottom: .35rem;
    }
    .filter-input {
        border: 1.5px solid var(--lib-border);
        border-radius: 8px; font-size: .875rem;
        background: var(--lib-cream);
        transition: border-color .2s, box-shadow .2s;
    }
    .filter-input:focus {
        border-color: var(--lib-amber);
        box-shadow: 0 0 0 3px rgba(201,129,58,.12);
        background: #fff;
    }
    .filter-actions { display: flex; gap: .5rem; align-items: flex-end; padding-bottom: 0; }
    .btn-filter-search {
        background: var(--lib-amber); color: #fff; border: none;
        border-radius: 8px; padding: .5rem 1.25rem; font-weight: 600; font-size: .875rem;
        transition: background .2s, transform .1s;
        white-space: nowrap;
    }
    .btn-filter-search:hover { background: #b56e28; transform: translateY(-1px); }
    .btn-filter-clear {
        background: var(--lib-warm); color: var(--lib-muted);
        border: 1px solid var(--lib-border);
        border-radius: 8px; padding: .5rem 1rem; font-size: .875rem;
        white-space: nowrap; text-decoration: none; font-weight: 500;
        transition: background .2s;
    }
    .btn-filter-clear:hover { background: var(--lib-border); color: var(--lib-ink); }

    /* ── Results Row ── */
    .results-row {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 1.25rem;
    }
    .results-count { font-size: .875rem; color: var(--lib-muted); }
    .filter-tag {
        display: inline-block; background: var(--lib-amber-lt);
        color: var(--lib-amber); font-size: .72rem; font-weight: 700;
        padding: .18em .6em; border-radius: 20px; margin-left: .5rem;
        text-transform: uppercase; letter-spacing: .05em;
    }

    /* ── Cards Grid ── */
    .books-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
        gap: 1.5rem;
    }

    /* ── Book Card ── */
    .book-card {
        background: #fff;
        border: 1px solid var(--lib-border);
        border-radius: var(--card-radius);
        overflow: hidden;
        display: flex; flex-direction: column;
        box-shadow: var(--lib-shadow);
        transition: transform .25s cubic-bezier(.4,0,.2,1), box-shadow .25s;
        animation: cardReveal .4s ease both;
    }
    @@keyframes cardReveal {
        from { opacity: 0; transform: translateY(14px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .book-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--lib-shadow-lg);
    }
    .book-card--unavailable { opacity: .72; }

    /* Cover */
    .book-cover-wrap {
        position: relative; height: 200px; overflow: hidden;
        background: linear-gradient(135deg, #ede8e0, #d5cabc);
    }
    .book-cover-img {
        width: 100%; height: 100%; object-fit: cover;
        transition: transform .4s;
    }
    .book-card:hover .book-cover-img { transform: scale(1.04); }
    .book-cover-placeholder {
        width: 100%; height: 100%;
        display: flex; align-items: center; justify-content: center;
        font-size: 3rem; color: #a89880;
    }
    .feat-desc {
    font-size: .72rem;
    color: var(--ink-muted);
    line-height: 1.5;

    margin-top: .4rem;

    display: -webkit-box;
    -webkit-line-clamp: 3;   /* عدد الأسطر */
    -webkit-box-orient: vertical;
    overflow: hidden;

    min-height: 2.2rem;
}

    /* Ribbon */
    .cover-ribbon {
        position: absolute; top: 10px; right: -24px;
        background: var(--lib-red); color: #fff;
        font-size: .65rem; font-weight: 700; letter-spacing: .07em;
        text-transform: uppercase; padding: .2em 2em;
        transform: rotate(35deg); box-shadow: 0 2px 6px rgba(0,0,0,.2);
    }
    .cover-ribbon--low { background: var(--lib-amber); }

    /* Category pill (shown on hover) */
    .cover-category {
        position: absolute; bottom: 8px; left: 8px;
        background: rgba(28,20,16,.72); color: #fff;
        font-size: .68rem; font-weight: 600; letter-spacing: .05em;
        padding: .2em .7em; border-radius: 20px; backdrop-filter: blur(4px);
        opacity: 0; transform: translateY(4px);
        transition: opacity .2s, transform .2s;
        text-transform: uppercase;
    }
    .book-card:hover .cover-category { opacity: 1; transform: translateY(0); }

    /* Body */
    .book-card-body { padding: .9rem 1rem .5rem; flex: 1; }
    .book-card-title {
        font-family: 'Lora', serif;
        font-size: .95rem; font-weight: 600; color: var(--lib-ink);
        margin-bottom: .3rem; line-height: 1.35;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    }
    .book-card-author {
        font-size: .78rem; color: var(--lib-muted); margin-bottom: .5rem;
    }
    .book-card-meta { display: flex; align-items: center; gap: .5rem; }
    .meta-qty {
        font-size: .72rem; font-weight: 700; padding: .22em .65em;
        border-radius: 20px; letter-spacing: .03em;
    }
    .qty-ok   { background: var(--lib-green-lt); color: var(--lib-green); }
    .qty-zero { background: var(--lib-red-lt);   color: var(--lib-red);   }

    /* Footer */
    .book-card-footer { padding: .75rem 1rem 1rem; border-top: 1px solid #f3ede4; }
    .btn-borrow {
        background: var(--lib-amber); color: #fff; border: none;
        border-radius: 8px; font-size: .82rem; font-weight: 600;
        padding: .5rem .75rem;
        transition: background .2s, transform .1s, box-shadow .2s;
    }
    .btn-borrow:hover {
        background: #b56e28; color: #fff; transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(201,129,58,.35);
    }
    .btn-borrow:active { transform: translateY(0); }
    .btn-borrow--ghost {
        background: transparent; color: var(--lib-amber);
        border: 1.5px solid var(--lib-amber);
    }
    .btn-borrow--ghost:hover { background: var(--lib-amber-lt); color: var(--lib-amber); }
    .btn-borrow--disabled {
        background: #e8e0d6; color: #a89880; border: none; cursor: not-allowed;
    }
    .btn-borrow--disabled:hover { background: #e8e0d6; transform: none; box-shadow: none; }

    /* ── Empty State ── */
    .empty-catalog {
        text-align: center; padding: 5rem 1rem;
        color: var(--lib-muted);
    }
    .empty-catalog-icon {
        width: 80px; height: 80px; border-radius: 50%;
        background: var(--lib-warm); border: 2px dashed var(--lib-border);
        display: flex; align-items: center; justify-content: center;
        font-size: 2rem; color: var(--lib-muted);
        margin: 0 auto 1.25rem;
    }
    .empty-catalog h4 { font-family: 'Lora', serif; color: var(--lib-ink); }

    /* ── Responsive ── */
    @@media (max-width: 640px) {
        .filter-bar-inner { flex-direction: column; }
        .filter-field, .filter-field--sm { flex: 1 1 100%; }
        .filter-actions { width: 100%; }
        .btn-filter-search, .btn-filter-clear { flex: 1; text-align: center; }
        .books-grid { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 1rem; }
        .book-cover-wrap { height: 160px; }
    }
</style>
}
