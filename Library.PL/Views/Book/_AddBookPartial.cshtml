@model Library.BLL.ModelVM.Book.AddBookVM
@using Library.DAL.Enums

<form id="addBookForm" asp-action="Add" asp-controller="Book" method="post" enctype="multipart/form-data" novalidate>
    @Html.AntiForgeryToken()

    <div class="row g-3">
        <!-- Title -->
        <div class="col-md-6">
            <label asp-for="Title" class="form-label fw-semibold">
                <i class="bi bi-type me-1 text-muted"></i>Title <span class="text-danger">*</span>
            </label>
            <input asp-for="Title" class="form-control" placeholder="Enter book title" />
            <span asp-validation-for="Title" class="text-danger small"></span>
        </div>

        <!-- Author -->
        <div class="col-md-6">
            <label asp-for="Author" class="form-label fw-semibold">
                <i class="bi bi-person me-1 text-muted"></i>Author <span class="text-danger">*</span>
            </label>
            <input asp-for="Author" class="form-control" placeholder="Enter author name" />
            <span asp-validation-for="Author" class="text-danger small"></span>
        </div>

        <!-- Category -->
        <div class="col-md-6">
            <label asp-for="Category" class="form-label fw-semibold">
                <i class="bi bi-tag me-1 text-muted"></i>Category <span class="text-danger">*</span>
            </label>
            <select asp-for="Category" asp-items="Html.GetEnumSelectList<Category>()" class="form-select">
                <option value="">— Select category —</option>
            </select>
            <span asp-validation-for="Category" class="text-danger small"></span>
        </div>

        <!-- Quantity -->
        <div class="col-md-6">
            <label asp-for="Quantity" class="form-label fw-semibold">
                <i class="bi bi-hash me-1 text-muted"></i>Quantity <span class="text-danger">*</span>
            </label>
            <input asp-for="Quantity" type="number" min="0" class="form-control" placeholder="0" />
            <span asp-validation-for="Quantity" class="text-danger small"></span>
        </div>

        <!-- Description -->
        <div class="col-12">
            <label asp-for="Description" class="form-label fw-semibold">
                <i class="bi bi-text-paragraph me-1 text-muted"></i>Description <span class="text-danger">*</span>
            </label>
            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Enter book description…"></textarea>
            <span asp-validation-for="Description" class="text-danger small"></span>
        </div>

        <!-- Image Upload -->
        <div class="col-12">
            <label asp-for="Image" class="form-label fw-semibold">
                <i class="bi bi-image me-1 text-muted"></i>Cover Image <span class="text-muted small fw-normal">(optional)</span>
            </label>
            <div class="image-upload-wrapper">
                <label for="addImageInput" class="image-upload-label d-flex align-items-center gap-3">
                    <div class="upload-icon-box">
                        <i class="bi bi-cloud-arrow-up"></i>
                    </div>
                    <div>
                        <div class="fw-semibold small">Click to upload image</div>
                        <div class="text-muted" style="font-size:.75rem">PNG, JPG, WEBP up to 5MB</div>
                    </div>
                </label>
                <input type="file" id="addImageInput" asp-for="Image" accept="image/*"
                       class="d-none image-upload-input" data-preview="addImagePreview" />
            </div>
            <img id="addImagePreview" src="#" alt="Preview"
                 class="mt-2 rounded border" style="display:none;max-height:120px;max-width:200px;object-fit:cover;" />
        </div>
    </div>

    <!-- Footer -->
    <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
        <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">
            <i class="bi bi-x-lg me-1"></i>Cancel
        </button>
        <button type="submit" class="btn px-4" style="background:var(--amber);color:#fff;">
            <i class="bi bi-plus-lg me-2"></i>Add Book
        </button>
    </div>
</form>

<style>
    .image-upload-wrapper {
        border: 2px dashed #cbd5e1;
        border-radius: 10px;
        padding: .75rem 1rem;
        cursor: pointer;
        transition: border-color .2s, background .2s;
    }
    .image-upload-wrapper:hover { border-color: #6366f1; background: #f8f7ff; }
    .image-upload-label { cursor: pointer; margin: 0; }
    .upload-icon-box {
        width: 40px; height: 40px;
        background: #ede9fe;
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.2rem; color: #6d28d9;
        flex-shrink: 0;
    }
</style>
