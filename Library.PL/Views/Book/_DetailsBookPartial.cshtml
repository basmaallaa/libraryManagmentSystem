@model Library.BLL.ModelVM.Book.BookVM
@using Library.DAL.Enums

<div class="book-details-wrapper">
    <div class="row g-0">
        <!-- Cover Column -->
        <div class="col-md-4 details-cover-col d-flex align-items-center justify-content-center p-4">
            @if (!string.IsNullOrEmpty(Model.ImagePath))
            {
                <img src="~/files/@Model.ImagePath" alt="@Model.Title"
                     class="book-cover-img rounded shadow" />
            }
            else
            {
                <div class="no-cover-placeholder rounded d-flex flex-column align-items-center justify-content-center">
                    <i class="bi bi-book display-3 text-muted opacity-50"></i>
                    <span class="text-muted small mt-2">No cover image</span>
                </div>
            }
        </div>

        <!-- Info Column -->
        <div class="col-md-8 p-4">
            <!-- Title & Category -->
            <div class="mb-3">
                <span class="badge category-badge category-@Model.Category.ToString().ToLower() mb-2">
                    @Model.Category
                </span>
                <h4 class="details-title mb-1">@Model.Title</h4>
                <div class="details-author">
                    <i class="bi bi-person-circle me-1 text-muted"></i>
                    <span class="text-muted">by</span>
                    <strong class="ms-1">@Model.Author</strong>
                </div>
            </div>

            <hr class="my-3" />

            <!-- Info Grid -->
            <div class="details-info-grid">
                
                <div class="info-item">
                    <div class="info-label">
                        <i class="bi bi-layers me-1"></i>Quantity
                    </div>
                    <div class="info-value">
                        <span class="qty-badge @(Model.Quantity == 0 ? "qty-zero" : Model.Quantity <= 3 ? "qty-low" : "qty-ok")">
                            @Model.Quantity @(Model.Quantity == 1 ? "copy" : "copies")
                        </span>
                    </div>
                </div>
            </div>

            <!-- Description -->
            <div class="mt-3">
                <div class="info-label mb-1">
                    <i class="bi bi-text-paragraph me-1"></i>Description
                </div>
                <p class="details-description mb-0">@Model.Description</p>
            </div>
        </div>
    </div>
</div>

<!-- Footer Actions -->
<div class="d-flex justify-content-end gap-2 px-3 pb-3 pt-2 border-top mt-2">
    <button class="btn btn-outline-warning btn-sm px-3"
            onclick="bootstrap.Modal.getInstance(document.getElementById('detailsBookModal')).hide(); setTimeout(() => loadEdit(@Model.Id), 300);">
        <i class="bi bi-pencil me-1"></i>Edit
    </button>
    <button class="btn btn-outline-danger btn-sm px-3"
            onclick="bootstrap.Modal.getInstance(document.getElementById('detailsBookModal')).hide(); setTimeout(() => confirmDelete(@Model.Id, '@Html.Raw(Model.Title.Replace("'","\'"))'), 300);">
        <i class="bi bi-trash3 me-1"></i>Delete
    </button>
    <button type="button" class="btn btn-light btn-sm px-3" data-bs-dismiss="modal">
        <i class="bi bi-x-lg me-1"></i>Close
    </button>
</div>

<style>
    .details-cover-col {
        background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
        border-radius: 0;
    }
    .book-cover-img {
        width: 140px;
        height: 190px;
        object-fit: cover;
        border: 3px solid #fff;
    }
    .no-cover-placeholder {
        width: 140px;
        height: 190px;
        background: #fff;
        border: 2px dashed #cbd5e1;
    }
    .details-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: #0f172a;
        line-height: 1.3;
    }
    .details-author {
        font-size: .9rem;
        color: #64748b;
    }
    .details-info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .75rem;
    }
    .info-item {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: .6rem .85rem;
    }
    .info-label {
        font-size: .7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .07em;
        color: #94a3b8;
        margin-bottom: .2rem;
    }
    .info-value {
        font-weight: 600;
        color: #1e293b;
        font-size: .9rem;
    }
    .details-description {
        font-size: .88rem;
        color: #475569;
        line-height: 1.6;
    }
    /* Re-declare shared badge styles (partials load in isolation) */
    .category-badge {
        font-size: .7rem; font-weight: 600;
        padding: .3em .65em; border-radius: 20px; letter-spacing: .04em;
    }
    .category-fiction    { background:#ede9fe; color:#6d28d9; }
    .category-nonfiction { background:#dcfce7; color:#166534; }
    .category-science    { background:#dbeafe; color:#1d4ed8; }
    .category-history    { background:#fef3c7; color:#92400e; }
    .category-technology { background:#e0f2fe; color:#0369a1; }
    .category-art        { background:#fce7f3; color:#9d174d; }
    .category-other      { background:#f1f5f9; color:#475569; }
    .qty-badge { display:inline-block; min-width:36px; padding:.25em .6em; border-radius:20px; font-size:.8rem; font-weight:700; }
    .qty-ok    { background:#dcfce7; color:#15803d; }
    .qty-low   { background:#fef3c7; color:#b45309; }
    .qty-zero  { background:#fee2e2; color:#dc2626; }
</style>
