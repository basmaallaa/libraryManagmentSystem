@model IEnumerable<Library.BLL.ModelVM.Book.BookVM>
@using Library.DAL.Enums

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Books Library";
}

<!-- Page Header -->
<div class="page-header mb-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <p class="admin-eyebrow mb-0">Manage your library collection</p>
            <h1 class="page-title mb-1">
                <i class="admin-section-title"></i>Books Library
            </h1>
            
        </div>
        <button class="btn  btn-add" style="background:var(--amber);color:#fff;" data-bs-toggle="modal" data-bs-target="#addBookModal">
            <i class="bi bi-plus-lg me-2"></i>Add New Book
        </button>
    </div>
</div>

<!-- Alert Messages -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (ViewBag.Error != null)
{
    <div class="alert alert-warning alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewBag.Error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Books Table Card -->
<div class="card books-card shadow-sm">
    <div class="admin-card-header d-flex align-items-center justify-content-between py-3">
        <div class="d-flex align-items-center gap-2">
            <span class="fw-semibold">All Books</span>
            <span class="badge  rounded-pill" style="background:var(--amber);color:#fff;">@(Model?.Count() ?? 0)</span>
        </div>
        <div class="input-group search-group">
            <span class="input-group-text bg-transparent border-end-0">
                <i class="bi bi-search text-muted"></i>
            </span>
            <input type="text" id="tableSearch" class="form-control border-start-0" placeholder="Search books…">
        </div>
    </div>

    <div class="card-body p-0">
        @if (Model == null || !Model.Any())
        {
            <div class="empty-state text-center py-5">
                <i class="bi bi-bookshelf display-1 text-muted opacity-25"></i>
                <h5 class="mt-3 text-muted">No books found</h5>
                <p class="text-muted small">Start by adding your first book to the library.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover books-table mb-0" id="booksTable">
                    <thead>
                        <tr>
                            <th style="width:60px">#</th>
                            <th style="width:70px">Cover</th>
                            <th>Title</th>
                            <th>Author</th>
                            <th>Category</th>
                            <th>Description</th>
                            <th class="text-center">Quantity</th>
                            <th class="text-center" style="width:180px">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int index = 1; }
                        @foreach (var book in Model)
                        {
                            <tr>
                                <td class="text-muted small align-middle">@(index++)</td>
                                <td class="align-middle">
                                    @if (!string.IsNullOrEmpty(book.ImagePath))
                                    {
                                        <img src="~/files/@book.ImagePath" alt="@book.Title"
                                             class="book-thumb rounded" />
                                    }
                                    else
                                    {
                                        <div class="book-thumb-placeholder rounded d-flex align-items-center justify-content-center">
                                            <i class="bi bi-book text-muted"></i>
                                        </div>
                                    }
                                </td>
                                <td class="align-middle fw-semibold">@book.Title</td>
                                <td class="align-middle text-muted">@book.Author</td>
                                <td class="align-middle">
                                    <span class="badge category-badge category-@book.Category.ToString().ToLower()">
                                        @book.Category
                                    </span>
                                </td>
                                <td class="align-middle text-muted">@book.Description</td>
                                <td class="align-middle text-center">
                                    <span class="qty-badge @(book.Quantity == 0 ? "qty-zero" : book.Quantity <= 3 ? "qty-low" : "qty-ok")">
                                        @book.Quantity
                                    </span>
                                </td>
                                <td class="align-middle text-center">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <button type="button"
                                                class="btn btn-outline-info btn-action"
                                                title="Details"
                                                onclick="loadDetails(@book.Id)">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <button type="button"
                                                class="btn btn-outline-warning btn-action"
                                                title="Edit"
                                                onclick="loadEdit(@book.Id)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button type="button"
                                                class="btn btn-outline-danger btn-action"
                                                title="Delete"
                                                onclick="confirmDelete(@book.Id, '@Html.Raw(book.Title.Replace("'", "\\'"))')">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- ===================== ADD BOOK MODAL ===================== -->
<div class="modal fade" id="addBookModal" tabindex="-1" aria-labelledby="addBookModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addBookModalLabel">
                    <i class="bi bi-plus-circle me-2 text-primary"></i>Add New Book
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="addBookModalBody">
                <partial name="_AddBookPartial" model="new Library.BLL.ModelVM.Book.AddBookVM()" />
            </div>
        </div>
    </div>
</div>

<!-- ===================== EDIT BOOK MODAL ===================== -->
<div class="modal fade" id="editBookModal" tabindex="-1" aria-labelledby="editBookModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editBookModalLabel">
                    <i class="bi bi-pencil-square me-2 text-warning"></i>Edit Book
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="editBookModalBody">
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===================== DETAILS MODAL ===================== -->
<div class="modal fade" id="detailsBookModal" tabindex="-1" aria-labelledby="detailsBookModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="detailsBookModalLabel">
                    <i class="bi bi-info-circle me-2 text-info"></i>Book Details
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="detailsBookModalBody">
                <div class="text-center py-4">
                    <div class="spinner-border text-info" role="status"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===================== DELETE CONFIRMATION MODAL ===================== -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0">
            <div class="modal-body text-center p-4">
                <div class="delete-icon-wrap mb-3">
                    <i class="bi bi-trash3-fill text-danger" style="font-size:2.5rem"></i>
                </div>
                <h5 class="fw-bold mb-1">Delete Book?</h5>
                <p class="text-muted small mb-3">
                    You are about to delete <strong id="deleteBookTitle"></strong>. This action cannot be undone.
                </p>
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <div class="d-flex gap-2 justify-content-center">
                        <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash3 me-1"></i>Delete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
<style>
    /* ── Typography & Base ── */
    .page-title {
        font-size: 1.6rem;
        font-weight: 700;
        color: #1e293b;
        letter-spacing: -0.02em;
    }

    /* ── Header Button ── */
    .btn-add {
        font-weight: 600;
        padding: .55rem 1.25rem;
        border-radius: 8px;
        letter-spacing: .01em;
    }

    /* ── Card ── */
    .books-card {
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        overflow: hidden;
    }
    .books-card .card-header {
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
    }

    /* ── Search ── */
    .search-group {
        max-width: 240px;
    }
    .search-group .form-control,
    .search-group .input-group-text {
        border-color: #e2e8f0;
        border-radius: 8px;
        font-size: .875rem;
    }
    .search-group .input-group-text { border-radius: 8px 0 0 8px; }
    .search-group .form-control      { border-radius: 0 8px 8px 0; }

    /* ── Table ── */
    .books-table thead tr {
        background: #f1f5f9;
    }
    .books-table thead th {
        font-size: .75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #64748b;
        border-bottom: 1px solid #e2e8f0;
        padding: .85rem 1rem;
    }
    .books-table tbody td {
        padding: .75rem 1rem;
        border-bottom: 1px solid #f1f5f9;
        vertical-align: middle;
    }
    .books-table tbody tr:last-child td { border-bottom: none; }
    .books-table tbody tr:hover { background: #f8fafc; }

    /* ── Book Thumbnail ── */
    .book-thumb {
        width: 42px;
        height: 56px;
        object-fit: cover;
        border: 1px solid #e2e8f0;
    }
    .book-thumb-placeholder {
        width: 42px;
        height: 56px;
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        font-size: 1.1rem;
    }

    /* ── Category Badges ── */
    .category-badge {
        font-size: .7rem;
        font-weight: 600;
        padding: .3em .65em;
        border-radius: 20px;
        letter-spacing: .04em;
    }
    .category-programming{ background:#ede9fe; color:#6d28d9; }
    .category-religion   { background:#dcfce7; color:#166534; }
    .category-science    { background:#dbeafe; color:#1d4ed8; }
    .category-history    { background:#fef3c7; color:#92400e; }
    .category-business   { background:#e0f2fe; color:#0369a1; }
    .category-novels     { background:#fce7f3; color:#9d174d; }
    .category-other      { background:#f1f5f9; color:#475569; }
    /* fallback for any unknown */
    .category-badge:not([class*="category-"]) { background:#f1f5f9; color:#475569; }

    /* ── Quantity Badge ── */
    .qty-badge {
        display: inline-block;
        min-width: 36px;
        padding: .25em .6em;
        border-radius: 20px;
        font-size: .8rem;
        font-weight: 700;
        text-align: center;
    }
    .qty-ok   { background:#dcfce7; color:#15803d; }
    .qty-low  { background:#fef3c7; color:#b45309; }
    .qty-zero { background:#fee2e2; color:#dc2626; }

    /* ── Action Buttons ── */
    .btn-action {
        border-radius: 6px !important;
        width: 32px;
        height: 32px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: .85rem;
    }

    /* ── Empty State ── */
    .empty-state { padding: 3rem 1rem; }

    /* ── Modals ── */
    .modal-content {
        border: none;
        border-radius: 16px;
        box-shadow: 0 25px 60px rgba(0,0,0,.15);
    }
    .modal-header {
        border-bottom: 1px solid #f1f5f9;
        padding: 1.25rem 1.5rem;
    }
    .modal-footer {
        border-top: 1px solid #f1f5f9;
        padding: 1rem 1.5rem;
    }
    .modal-body { padding: 1.5rem; }

    /* ── Delete modal icon ── */
    .delete-icon-wrap {
        width: 64px;
        height: 64px;
        background: #fee2e2;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
    }
</style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
<script>
    // ── Live Table Search ──────────────────────────────────────
    document.getElementById('tableSearch').addEventListener('input', function () {
        const q = this.value.toLowerCase();
        document.querySelectorAll('#booksTable tbody tr').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    });

    // ── Delete Confirmation ────────────────────────────────────
    function confirmDelete(id, title) {
        document.getElementById('deleteBookTitle').textContent = title;
        document.getElementById('deleteForm').action = '/Book/Delete/' + id;
        new bootstrap.Modal(document.getElementById('deleteModal')).show();
    }

    // ── Load Details via AJAX ──────────────────────────────────
    function loadDetails(id) {
        const modalBody = document.getElementById('detailsBookModalBody');
        modalBody.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-info" role="status"></div></div>';
        const modal = new bootstrap.Modal(document.getElementById('detailsBookModal'));
        modal.show();
        fetch('/Book/DetailsPartial/' + id)
            .then(r => r.ok ? r.text() : Promise.reject(r.status))
            .then(html => { modalBody.innerHTML = html; })
            .catch(() => {
                modalBody.innerHTML = '<div class="alert alert-danger m-3"><i class="bi bi-exclamation-circle me-2"></i>Failed to load book details.</div>';
            });
    }

    // ── Load Edit via AJAX ─────────────────────────────────────
    function loadEdit(id) {
        const modalBody = document.getElementById('editBookModalBody');
        const modalEl = document.getElementById('editBookModal');
        const modal = new bootstrap.Modal(modalEl);
        modal.show();
        modalBody.innerHTML = '<div class="text-center py-4"><div class="spinner-border text-warning" role="status"></div></div>';
        fetch('/Book/EditPartial/' + id)
            .then(r => {
            if (!r.ok) throw new Error("HTTP Error " + r.status);
            return r.text();
        })
            .then(html => {
                modalBody.innerHTML = html;
                // Re-bind Bootstrap validation on injected form
                const form = modalBody.querySelector('form');
                if (form && window.jQuery && $.validator) {
                    $.validator.unobtrusive.parse(form);
                }
                initImagePreviews();
            })
            .catch(err => {
                console.error(err);
                modalBody.innerHTML = '<div class="alert alert-danger m-3"><i class="bi bi-exclamation-circle me-2"></i>Failed to load edit form.</div>';
            });
    }

    // ── Image Preview ──────────────────────────────────────────
    function initImagePreviews() {
        document.querySelectorAll('.image-upload-input').forEach(input => {
            input.addEventListener('change', function () {
                const preview = document.getElementById(this.dataset.preview);
                if (preview && this.files && this.files[0]) {
                    const reader = new FileReader();
                    reader.onload = e => {
                        preview.src = e.target.result;
                        preview.style.display = 'block';
                    };
                    reader.readAsDataURL(this.files[0]);
                }
            });
        });
    }
    initImagePreviews();

    // ── Handle Add Form AJAX Submit ────────────────────────────
    document.addEventListener('submit', function (e) {
        const form = e.target;
        if (form.id === 'addBookForm' || form.id === 'editBookForm') {
            e.preventDefault();
            if (!$(form).valid()) return;

            const btn = form.querySelector('[type=submit]');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving…';

            const fd = new FormData(form);
            fetch(form.action, { method: 'POST', body: fd })
                .then(r => {
                    if (r.redirected || r.ok) {
                        // Check if server returned validation errors (partial HTML)
                        return r.text().then(html => ({ html, redirected: r.redirected, url: r.url }));
                    }
                    return Promise.reject('Server error');
                })
                .then(({ html, redirected, url }) => {
                    // If redirected to Index, reload page
                    if (redirected && url && url.includes('/Book')) {
                        location.reload();
                        return;
                    }
                    // Try to detect success by checking if response is a redirect
                    // If validation failed, server returns the partial again
                    if (html.includes('field-validation-error') || html.includes('text-danger')) {
                        const bodyId = form.id === 'addBookForm' ? 'addBookModalBody' : 'editBookModalBody';
                        document.getElementById(bodyId).innerHTML = html;
                        initImagePreviews();
                        $.validator.unobtrusive.parse(form);
                        btn.disabled = false;
                        btn.innerHTML = form.id === 'addBookForm'
                            ? '<i class="bi bi-plus-lg me-2"></i>Add Book'
                            : '<i class="bi bi-check-lg me-2"></i>Save Changes';
                    } else {
                        location.reload();
                    }
                })
                .catch(() => { location.reload(); });
        }
    });
</script>
}
