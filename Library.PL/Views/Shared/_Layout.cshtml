@using Library.DAL.Models
@using Microsoft.AspNetCore.Identity

@inject UserManager<ApplicationUser> UserManager

@{
    var currentUser = await UserManager.GetUserAsync(User);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bibliotheca</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,500;0,600;0,700;1,500&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)

    <style>
        /* ── Global Tokens ───────────────────────────────── */
        :root {
            --ink:        #1c1410;
            --ink-muted:  #6b5f54;
            --cream:      #faf7f2;
            --warm:       #f5efe4;
            --border:     #e8dfd0;
            --amber:      #c9813a;
            --amber-dark: #a3641e;
            --amber-lt:   #fdf0e0;
            --nav-h:      68px;
        }

        *, *::before, *::after { box-sizing: border-box; }

        html { scroll-behavior: smooth; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--cream);
            color: var(--ink);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        main { flex: 1; }

        /* ── Navbar ──────────────────────────────────────── */
        .site-nav {
            height: var(--nav-h);
            background: #fff;
            border-bottom: 1px solid var(--border);
            box-shadow: 0 1px 12px rgba(60,40,10,.07);
            position: sticky;
            top: 0;
            z-index: 1030;
        }

        .nav-brand {
            display: flex;
            align-items: center;
            gap: .55rem;
            text-decoration: none;
        }
        .nav-brand-icon {
            width: 36px; height: 36px;
            background: var(--ink);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            color: var(--amber);
            font-size: 1.1rem;
            flex-shrink: 0;
        }
        .nav-brand-text {
            font-family: 'Lora', serif;
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--ink);
            letter-spacing: -.01em;
        }
        .nav-brand-text em {
            font-style: italic;
            color: var(--amber);
        }

        .site-nav .nav-link {
            font-size: .875rem;
            font-weight: 500;
            color: var(--ink-muted) !important;
            padding: .45rem .7rem;
            border-radius: 6px;
            transition: color .18s, background .18s;
            position: relative;
        }
        .site-nav .nav-link:hover,
        .site-nav .nav-link.active {
            color: var(--ink) !important;
            background: var(--warm);
        }

        .site-nav .nav-link.nav-link-badge::after {
            content: 'New';
            font-size: .6rem;
            font-weight: 700;
            background: var(--amber);
            color: #fff;
            padding: .08em .4em;
            border-radius: 10px;
            margin-left: .35rem;
            vertical-align: middle;
            letter-spacing: .04em;
        }

        /* User greeting */
        .nav-user {
            display: flex;
            align-items: center;
            gap: .45rem;
            font-size: .84rem;
            font-weight: 600;
            color: var(--ink);
            padding: .35rem .75rem;
            background: var(--warm);
            border: 1px solid var(--border);
            border-radius: 24px;
        }
        .nav-user-avatar {
            width: 26px; height: 26px;
            border-radius: 50%;
            background: var(--ink);
            color: var(--amber);
            font-size: .72rem;
            font-weight: 700;
            display: flex; align-items: center; justify-content: center;
        }

        .btn-nav-login {
            font-size: .84rem;
            font-weight: 600;
            color: var(--ink-muted);
            padding: .38rem .85rem;
            border-radius: 6px;
            text-decoration: none;
            transition: color .18s, background .18s;
        }
        .btn-nav-login:hover { color: var(--ink); background: var(--warm); }

        .btn-nav-register {
            font-size: .84rem;
            font-weight: 600;
            background: var(--ink);
            color: #fff;
            padding: .4rem 1rem;
            border-radius: 8px;
            text-decoration: none;
            transition: background .2s;
        }
        .btn-nav-register:hover { background: #3a2510; color: #fff; }

        .btn-nav-logout {
            font-size: .84rem;
            font-weight: 600;
            color: #dc2626;
            background: none;
            border: none;
            padding: .38rem .75rem;
            border-radius: 6px;
            cursor: pointer;
            transition: background .18s;
        }
        .btn-nav-logout:hover { background: #fee2e2; }

        /* ── Role-specific nav accent ── */
        .nav-role-admin {
            font-size: .68rem;
            font-weight: 700;
            letter-spacing: .07em;
            text-transform: uppercase;
            background: #1e3a5f;
            color: #93c5fd;
            padding: .15em .55em;
            border-radius: 4px;
            margin-left: .35rem;
            vertical-align: middle;
        }

        /* ── Footer ──────────────────────────────────────── */
        .site-footer {
            background: var(--ink);
            color: #c8b89a;
            padding: 3rem 0 0;
            margin-top: auto;
        }

        .footer-brand {
            display: flex;
            align-items: center;
            gap: .55rem;
            margin-bottom: .85rem;
        }
        .footer-brand-icon {
            width: 34px; height: 34px;
            background: rgba(255,255,255,.08);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            color: var(--amber);
            font-size: 1rem;
        }
        .footer-brand-text {
            font-family: 'Lora', serif;
            font-size: 1.1rem;
            font-weight: 700;
            color: #fff;
        }
        .footer-brand-text em { font-style: italic; color: var(--amber); }
        .footer-tagline { font-size: .82rem; color: #9a8870; line-height: 1.55; max-width: 260px; }

        .footer-heading {
            font-size: .7rem;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: #6b5f50;
            margin-bottom: .9rem;
        }
        .footer-links { list-style: none; padding: 0; margin: 0; }
        .footer-links li { margin-bottom: .45rem; }
        .footer-links a {
            font-size: .84rem;
            color: #9a8870;
            text-decoration: none;
            transition: color .18s;
        }
        .footer-links a:hover { color: var(--amber); }

        .footer-divider {
            border-color: rgba(255,255,255,.08);
            margin: 2rem 0 0;
        }
        .footer-bottom {
            padding: 1rem 0;
            font-size: .78rem;
            color: #6b5f50;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: .5rem;
        }
        .footer-bottom a { color: #9a8870; text-decoration: none; }
        .footer-bottom a:hover { color: var(--amber); }

        /* ── Navbar toggler on mobile ── */
        .navbar-toggler { border: 1px solid var(--border); border-radius: 8px; }
        .navbar-toggler:focus { box-shadow: 0 0 0 3px rgba(201,129,58,.2); }
        .navbar-toggler-icon {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba%2828,20,16, 0.75%29' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
        }

        /* ── Page wrapper (removes old container constraint for full-width pages) ── */
        .page-body { flex: 1; }

        /* ── Scrollbar ── */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #d6ccbe; border-radius: 3px; }
    </style>
</head>
<body>
    <!-- ═══════════════════════ NAVBAR ═══════════════════════ -->
    <header>
        <nav class="site-nav navbar navbar-expand-lg">
            <div class="container">

                <!-- Brand -->
                <a class="nav-brand navbar-brand" asp-controller="Home" asp-action="Index">
                    <div class="nav-brand-icon"><i class="bi bi-book-half"></i></div>
                    <span class="nav-brand-text">Biblio<em>theca</em></span>
                </a>

                <!-- Mobile toggle -->
                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <!-- Left links -->
                    <ul class="navbar-nav me-auto mt-2 mt-lg-0 gap-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house me-1 opacity-60"></i>Home
                            </a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("User"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Library" asp-action="Index">
                                    <i class="bi bi-bookshelf me-1 opacity-60"></i>Browse
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Library" asp-action="MyBorrowedBooks">
                                    <i class="bi bi-bookmark-check me-1 opacity-60"></i>My Books
                                </a>
                            </li>
                        }

                        @if (User.Identity?.IsAuthenticated != true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Library" asp-action="Index">
                                    <i class="bi bi-bookshelf me-1 opacity-60"></i>Browse
                                </a>
                            </li>
                        }

                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">
                                    <i class="bi bi-grid me-1 opacity-60"></i>Dashboard
                                    <span class="nav-role-admin">Admin</span>
                                </a>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Privacy">
                                <i class="bi bi-shield-check me-1 opacity-60"></i>Privacy
                            </a>
                        </li>
                    </ul>

                    <!-- Right side -->
                    <ul class="navbar-nav align-items-center gap-2 mt-2 mt-lg-0">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <div class="nav-user">
                                    <div class="nav-user-avatar">
                                    @(currentUser?.FullName?.Length > 0
                                    ? currentUser.FullName[0].ToString().ToUpper()
                                    : "U")</div>
                                    @(currentUser?.FullName ?? "User")
                                </div>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-nav-logout">
                                        <i class="bi bi-box-arrow-right me-1"></i>Logout
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn-nav-login" asp-controller="Auth" asp-action="Login">
                                    Login
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="btn-nav-register" asp-controller="Auth" asp-action="Register">
                                    Get Started
                                </a>
                            </li>
                        }
                    </ul>
                </div>

            </div>
        </nav>
    </header>

    <!-- ═══════════════════════ BODY ═════════════════════════ -->
    <main class="page-body" role="main">
        @RenderBody()
    </main>

    <!-- ═══════════════════════ FOOTER ══════════════════════ -->
    <footer class="site-footer">
        <div class="container">
            <div class="row g-4 pb-4">
                <!-- Brand col -->
                <div class="col-lg-4 col-md-6">
                    <div class="footer-brand">
                        <div class="footer-brand-icon"><i class="bi bi-book-half"></i></div>
                        <span class="footer-brand-text">Biblio<em>theca</em></span>
                    </div>
                    <p class="footer-tagline">
                        A modern library management system — discover, borrow, and return books with ease.
                    </p>
                </div>

                <!-- Quick links -->
                <div class="col-lg-2 col-md-6 col-6">
                    <h6 class="footer-heading">Explore</h6>
                    <ul class="footer-links">
                        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                        <li><a asp-controller="Library" asp-action="Index">Browse Books</a></li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li><a asp-controller="Library" asp-action="MyBorrowedBooks">My Books</a></li>
                        }
                    </ul>
                </div>

                <!-- Account links -->
                <div class="col-lg-2 col-md-6 col-6">
                    <h6 class="footer-heading">Account</h6>
                    <ul class="footer-links">
                        @if (User.Identity?.IsAuthenticated != true)
                        {
                            <li><a asp-controller="Auth" asp-action="Login">Login</a></li>
                            <li><a asp-controller="Auth" asp-action="Register">Register</a></li>
                        }
                        else
                        {
                            <li><span style="color:#6b5f50;font-size:.84rem;">Signed in as @User.Identity.Name</span></li>
                        }
                        <li><a asp-controller="Home" asp-action="Privacy">Privacy Policy</a></li>
                    </ul>
                </div>

                <!-- Contact / info -->
                <div class="col-lg-4 col-md-6">
                    <h6 class="footer-heading">About</h6>
                    <p style="font-size:.83rem;color:#9a8870;line-height:1.6;">
                        Bibliotheca is a digital library management platform. Browse our curated collection, borrow your favourites, and manage your reading history — all in one place.
                    </p>
                    <div class="d-flex gap-2 mt-2">
                        <a href="#" class="footer-social-btn" aria-label="Twitter">
                            <i class="bi bi-twitter-x"></i>
                        </a>
                        <a href="#" class="footer-social-btn" aria-label="Facebook">
                            <i class="bi bi-facebook"></i>
                        </a>
                        <a href="#" class="footer-social-btn" aria-label="Instagram">
                            <i class="bi bi-instagram"></i>
                        </a>
                    </div>
                </div>
            </div>

            <hr class="footer-divider">

            <div class="footer-bottom">
                <span>&copy; @DateTime.Now.Year Bibliotheca. All rights reserved.</span>
                <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/jquery.validation/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/jquery.validation.unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <style>
        .footer-social-btn {
            width: 32px; height: 32px;
            display: flex; align-items: center; justify-content: center;
            background: rgba(255,255,255,.07);
            border-radius: 8px;
            color: #9a8870;
            font-size: .9rem;
            text-decoration: none;
            transition: background .2s, color .2s;
        }
        .footer-social-btn:hover { background: var(--amber); color: #fff; }
    </style>
</body>
</html>
