@model Library.BLL.ModelVM.Admin.UserListVM
@{
    ViewData["Title"] = "Users";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var users    = Model.Users?.ToList() ?? new List<Library.BLL.ModelVM.Admin.UserRowVM>();
    var active   = users.Count(u =>  u.IsActive);
    var inactive = users.Count(u => !u.IsActive);
}

<!-- ── Header ── -->
<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div>
        <p class="admin-eyebrow mb-0">Management</p>
        <h1 class="admin-section-title">Users</h1>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <span class="stat-chip stat-chip--green"><i class="bi bi-person-check me-1"></i>@active Active</span>
        <span class="stat-chip stat-chip--red"><i class="bi bi-person-dash me-1"></i>@inactive Inactive</span>
    </div>
</div>

<!-- ── Search ── -->
<form method="get" asp-action="Users" asp-controller="Admin" class="admin-card mb-4 p-3">
    <div class="row g-2 align-items-end">
        <div class="col-sm-8 col-md-6">
            <label class="filter-label-sm">Search Users</label>
            <div class="input-group input-group-sm">
                <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" name="searchQuery" value="@Model.SearchQuery"
                       class="form-control border-start-0" placeholder="Name or email…" style="border-radius:0 8px 8px 0" />
            </div>
        </div>
        <div class="col-sm-4 col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-sm w-100" style="background:var(--amber);color:#fff;border:none;border-radius:8px;font-weight:600;">
                <i class="bi bi-search me-1"></i>Search
            </button>
            @if (!string.IsNullOrEmpty(Model.SearchQuery))
            {
                <a asp-action="Users" asp-controller="Admin" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;">
                    <i class="bi bi-x"></i>
                </a>
            }
        </div>
    </div>
</form>

<!-- ── Users Table ── -->
<div class="admin-card">
    <div class="admin-card-header">
        <h2 class="admin-card-title">
            <i class="bi bi-people me-2" style="color:var(--amber)"></i>
            All Users
            <span style="background:var(--amber-lt);color:var(--amber);font-size:.7rem;font-weight:700;padding:.15em .6em;border-radius:20px;margin-left:.5rem">@users.Count</span>
        </h2>
        <input type="text" id="userSearch" class="form-control form-control-sm"
               style="max-width:220px;border-radius:8px" placeholder="Quick filter…" />
    </div>

    <div class="table-responsive">
        <table class="admin-table" id="usersTable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>User</th>
                    <th>Email</th>
                    <th class="text-center">Total Borrows</th>
                    <th class="text-center">Active Loans</th>
                    <th>Joined</th>
                    <th class="text-center">Status</th>
                    <th class="text-center" style="width:140px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!users.Any())
                {
                    <tr><td colspan="8" class="text-center py-5 text-muted">No users found</td></tr>
                }
                @{ int idx = 1; }
                @foreach (var user in users)
                {
                    <tr>
                        <td class="text-muted small">@(idx++)</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                @if (!string.IsNullOrEmpty(user.ProfileImage))
                                {
                                    <img src="~/users/@user.ProfileImage" class="user-avatar-img" alt="@user.FullName" />
                                }
                                else
                                {
                                    <div class="user-avatar-sm">
                                        @(user.FullName.Length > 0 ? user.FullName[0].ToString().ToUpper() : "U")
                                    </div>
                                }
                                <div>
                                    <div class="fw-semibold" style="font-size:.875rem">@user.FullName</div>
                                    <div style="font-size:.72rem;color:var(--muted)">ID: @user.Id[..8]…</div>
                                </div>
                            </div>
                        </td>
                        <td style="font-size:.84rem;color:var(--muted)">@user.Email</td>
                        <td class="text-center">
                            <span style="font-size:.85rem;font-weight:700;color:var(--ink)">@user.TotalBorrows</span>
                        </td>
                        <td class="text-center">
                            @if (user.ActiveBorrows > 0)
                            {
                                <span class="badge-active">@user.ActiveBorrows</span>
                            }
                            else
                            {
                                <span style="font-size:.8rem;color:var(--muted)">—</span>
                            }
                        </td>
                        <td style="font-size:.8rem;color:var(--muted)">@user.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td class="text-center">
                            @if (user.IsActive)
                            { <span class="badge-enabled"><i class="bi bi-check-circle me-1"></i>Active</span> }
                            else
                            { <span class="badge-disabled"><i class="bi bi-x-circle me-1"></i>Inactive</span> }
                        </td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center">
                                <!-- View History -->
                                <button type="button"
                                        class="action-btn action-btn-info"
                                        title="View History"
                                        onclick="loadUserHistory('@user.Id', '@Html.Raw(user.FullName.Replace("'","\'"))')">
                                    <i class="bi bi-clock-history"></i>
                                </button>
                                <!-- Toggle Active -->
                                <button type="button"
                                        class="action-btn @(user.IsActive ? "action-btn-warning" : "action-btn-success")"
                                        title="@(user.IsActive ? "Deactivate" : "Activate")"
                                        onclick="confirmToggle('@user.Id', '@Html.Raw(user.FullName.Replace("'","\'"))', @(user.IsActive ? "true" : "false"))">
                                    <i class="bi @(user.IsActive ? "bi-person-dash" : "bi-person-check")"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- ── Toggle Confirmation Modal ── -->
<div class="modal fade" id="toggleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content" style="border:none;border-radius:16px;box-shadow:0 20px 60px rgba(0,0,0,.15)">
            <div class="modal-body text-center p-4">
                <div id="toggleIconWrap" style="width:60px;height:60px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.6rem;margin:0 auto 1rem">
                </div>
                <h5 class="fw-bold mb-1" id="toggleModalTitle">Change User Status?</h5>
                <p class="text-muted small mb-3" id="toggleModalBody"></p>
                <form id="toggleForm" asp-controller="Admin" asp-action="ToggleActive" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="toggleUserId" name="userId" value="" />
                    <div class="d-flex gap-2 justify-content-center">
                        <button type="button" class="btn btn-sm btn-light px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" id="toggleConfirmBtn" class="btn btn-sm px-4" style="border:none;border-radius:8px;font-weight:600;">
                            Confirm
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- ── User History Modal ── -->
<div class="modal fade" id="historyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border:none;border-radius:16px;box-shadow:0 20px 60px rgba(0,0,0,.15)">
            <div class="modal-header" style="border-bottom:1px solid var(--border)">
                <h5 class="modal-title" style="font-family:'Lora',serif;font-weight:700">
                    <i class="bi bi-clock-history me-2" style="color:var(--amber)"></i>
                    Borrow History — <span id="historyUserName"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0" id="historyModalBody">
                <div class="text-center py-5">
                    <div class="spinner-border" style="color:var(--amber)" role="status"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
<style>
    .filter-label-sm { font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);margin-bottom:.25rem;display:block; }
    .stat-chip { font-size:.78rem;font-weight:700;padding:.28em .85em;border-radius:20px; }
    .stat-chip--green { background:var(--green-lt);color:var(--green); }
    .stat-chip--red   { background:var(--red-lt);  color:var(--red);   }
    .action-btn {
        width:30px;height:30px;border:none;border-radius:6px;
        display:inline-flex;align-items:center;justify-content:center;
        font-size:.82rem;cursor:pointer;transition:all .18s;
    }
    .action-btn-info    { background:var(--blue-lt); color:var(--blue); }
    .action-btn-info:hover { background:var(--blue); color:#fff; }
    .action-btn-warning { background:var(--amber-lt); color:var(--amber); }
    .action-btn-warning:hover { background:var(--amber); color:#fff; }
    .action-btn-success { background:var(--green-lt); color:var(--green); }
    .action-btn-success:hover { background:var(--green); color:#fff; }
</style>
}

@section Scripts {
<script>
    // Quick filter
    document.getElementById('userSearch').addEventListener('input', function () {
        const q = this.value.toLowerCase();
        document.querySelectorAll('#usersTable tbody tr').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    });

    // Toggle modal
    function confirmToggle(userId, name, isActive) {
        const active = isActive === true || isActive === 'true';
        document.getElementById('toggleUserId').value = userId;
        document.getElementById('toggleModalTitle').textContent = active ? 'Deactivate User?' : 'Activate User?';
        document.getElementById('toggleModalBody').textContent =
            active
                ? `${name} will be deactivated and unable to borrow books.`
                : `${name} will be reactivated and can borrow books again.`;

        const iconWrap = document.getElementById('toggleIconWrap');
        const confirmBtn = document.getElementById('toggleConfirmBtn');
        if (active) {
            iconWrap.style.cssText = 'background:var(--red-lt);color:var(--red);';
            iconWrap.innerHTML = '<i class="bi bi-person-dash-fill"></i>';
            confirmBtn.style.cssText = 'background:var(--red);color:#fff;';
            confirmBtn.textContent = 'Deactivate';
        } else {
            iconWrap.style.cssText = 'background:var(--green-lt);color:var(--green);';
            iconWrap.innerHTML = '<i class="bi bi-person-check-fill"></i>';
            confirmBtn.style.cssText = 'background:var(--green);color:#fff;';
            confirmBtn.textContent = 'Activate';
        }
        // Reapply shared size styles
        iconWrap.style.cssText += ';width:60px;height:60px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.6rem;margin:0 auto 1rem;';

        new bootstrap.Modal(document.getElementById('toggleModal')).show();
    }

    // History modal (AJAX)
    function loadUserHistory(userId, name) {
        document.getElementById('historyUserName').textContent = name;
        document.getElementById('historyModalBody').innerHTML =
            '<div class="text-center py-5"><div class="spinner-border" style="color:var(--amber)" role="status"></div></div>';
        new bootstrap.Modal(document.getElementById('historyModal')).show();
        fetch('/Admin/UserHistoryPartial/' + encodeURIComponent(userId))
            .then(r => r.ok ? r.text() : Promise.reject(r.status))
            .then(html => { document.getElementById('historyModalBody').innerHTML = html; })
            .catch(() => {
                document.getElementById('historyModalBody').innerHTML =
                    '<div class="alert alert-danger m-3">Failed to load history.</div>';
            });
    }
</script>
}
